rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Venues: Public read, admin write only (so no client write)
      match /venues/{venueId} {
        allow read: if true;
        allow write: if false; 
      }
      
      // Slots: Public read, auth can update to book
      match /slots/{slotId} {
        allow read: if true;
        allow create: if false; // seeded by admin
        // Authenticated users can update a slot to book it
        allow update: if request.auth != null;
        allow delete: if false;
      }

      // Bookings: Auth users can create and manage their own
      match /bookings/{bookingId} {
        allow read: if request.auth != null && request.auth.uid == resource.data.userId;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }

      // Games: Public read
      match /games/{gameId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.hostId;

        match /watchers/{userId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Users: Users can read their own profiles.
      match /users/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only Cloud Functions can update users
      }
    }
  }
}
